{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debug: level_infer.py",
            "type": "debugpy",
            "request": "launch",
            "program": "train.py", // 你的Python脚本路径
            "console": "integratedTerminal",
            "justMyCode": true,
            "args": [
                "--train_config",
                "configs/train/triplet.yaml",
                "--model_config",
                "configs/model/convnext-mlp.yaml",
                "--out_dir",
                "ckpt_convnext_large_d_320",
            ],
            "env": {
                "CUDA_VISIBLE_DEVICES": "4",
                "CUDA_LAUNCH_BLOCKING": "1"
            }
        }
    ]
}